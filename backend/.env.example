# ============================================================
# Monkey Backend — variabili d'ambiente
# Copia questo file in ".env" e compila i valori mancanti.
# Il file ".env" NON va mai committato (è già in .gitignore).
# ============================================================

# --- Server ---
PORT=4000
NODE_ENV=development

# Origini autorizzate per CORS (separate da virgola).
# Aggiungi qui l'URL da cui viene servito il front end Monkey.
# In locale, se apri i file .dc.html direttamente o tramite un
# semplice static server, indica l'origine usata (es. http://127.0.0.1:5500).
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# --- Supabase ---
# Si trovano in: Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Nome del bucket di storage per le immagini prodotto (creato dallo schema.sql)
SUPABASE_STORAGE_BUCKET=product-images

# --- Email (form di contatto) ---
# Opzione consigliata: Resend (piano free: 3000 email/mese, 100/giorno, nessuna carta richiesta)
# Vai su https://resend.com, crea un account free, genera una API key e usa il relay SMTP:
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=resend
SMTP_PASS=your-resend-api-key

# In alternativa puoi usare Gmail con una "App Password" (richiede 2FA attivo sull'account Google):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=tuo-indirizzo@gmail.com
# SMTP_PASS=app-password-16-caratteri

# Indirizzo mittente e destinatario per le email del form di contatto
CONTACT_FROM_EMAIL=onboarding@resend.dev
CONTACT_TO_EMAIL=tuo-indirizzo@gmail.com
